# Example Streamlit secrets file.
#
# Copy this file to `.streamlit/secrets.toml` and fill in real values for
# local development. In production (Streamlit Cloud), set these via the
# app's Secrets UI instead of committing a file.
#
# NEVER commit the real `.streamlit/secrets.toml` — it must stay gitignored.

[data_sources]
# Placeholders for future paid/keyed data providers. The current app uses
# yfinance and Stooq, both of which are public and need no credentials.
# tiingo_api_key = ""
# polygon_api_key = ""
# alpha_vantage_api_key = ""

[features]
# Toggle the Stooq fallback when the primary (yfinance) source fails or
# returns empty data. Set to false to force a single-source pipeline.
enable_stooq_fallback = true
